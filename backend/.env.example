# Copy to .env and fill in. Every value here is configuration — nothing is
# hardcoded in the app. (See README "Design principles".)

# --- Server ---
NASCINEMA_HOST=0.0.0.0
NASCINEMA_PORT=8400
# Public HTTPS URL your reverse proxy serves (used for share links). Optional.
NASCINEMA_PUBLIC_URL=
# Comma-separated allowed origins for CORS/WebSocket. * for dev.
NASCINEMA_CORS_ORIGINS=*

# --- Security ---
# Long random string. Signs auth + media tokens. CHANGE THIS.
NASCINEMA_SECRET_KEY=change-me-to-a-long-random-string

# --- Database (PostgreSQL, async psycopg3 driver) ---
NASCINEMA_DATABASE_URL=postgresql+psycopg://nascinema:nascinema@localhost:5432/nascinema

# --- Media ---
# One or more library folders, separated by your OS path separator
# (';' on Windows, ':' on Linux/macOS). Example (Windows):
#   NASCINEMA_MEDIA_DIRS=\\your-nas\Media\Movies;D:\More Movies
NASCINEMA_MEDIA_DIRS=
# Where the library cache (transcode segments, trickplay, OCR'd subs) lives.
NASCINEMA_DATA_DIR=.nascinema

# --- Integrations (all optional; features stay dormant until set) ---
# Free key from https://www.themoviedb.org/settings/api
NASCINEMA_TMDB_API_KEY=

# --- FFmpeg (auto-discovered if omitted; set to override) ---
NASCINEMA_FFMPEG=
NASCINEMA_FFPROBE=
